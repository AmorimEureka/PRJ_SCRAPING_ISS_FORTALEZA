# Portal ISS Fortaleza
PORTAL_PREFEITURA_FORTALEZA=https://iss.fortaleza.ce.gov.br/grpfor/home.seam
CPF_LOGIN=00000000000
# Use aspas simples quando a senha contiver $, por exemplo: 'senha$literal'
SENHA='altere-me'
NFSE_ISSUER_CNPJ=59932105000121
NFSE_DEFAULT_CITY=FORTALEZA
NFSE_DEFAULT_UF=CE

# PostgreSQL compartilhado com api_prontocardio
DATABASE_URL=postgresql://usuario:senha@host:5432/banco
POSTGRES_SCHEMA=api_prontocardio
NFSE_POSTGRES_CONN_ID=postgres_prontocardio
AIRFLOW_CONN_POSTGRES_PRONTOCARDIO=postgresql://usuario:senha@host:5432/banco

# Airflow/Astro
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session
NFSE_EXTRACTION_SCHEDULE=0 3 * * *
NFSE_DOWNLOADS_DIR=/usr/local/airflow/data/nfse
NFSE_ARTIFACTS_DIR=/usr/local/airflow/data/artifacts
